---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - Cerydra" description="The page you are looking for does not exist.">
  <main class="min-h-screen flex flex-col items-center justify-center bg-[var(--md-sys-color-background)] text-center px-6">
    <h1 class="text-6xl font-black text-[var(--md-sys-color-primary)] mb-4">404</h1>
    <p class="text-lg text-[var(--md-sys-color-on-surface-variant)] mb-8 max-w-md">Page not found. The page you are looking for doesn't exist or has been moved.</p>
    <a href="/" class="px-6 py-3 bg-[var(--md-sys-color-primary)] text-[var(--md-sys-color-on-primary)] font-bold rounded-xl hover:opacity-90 transition-opacity">Go Home</a>
  </main>
</Layout>
