---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - Cerydra" description="Cerydra is an open source anime streaming app built with Astro, React, and Material UI.">
  <main class="p-8 text-[var(--md-sys-color-on-background)] bg-[var(--md-sys-color-background)] min-h-screen font-sans">
    <h1 class="text-2xl font-bold mb-4">About Cerydra</h1>
    <p class="text-[var(--md-sys-color-on-surface-variant)]">Cerydra is an open source anime streaming app built with Astro, React, and Material UI.</p>
    <a href="/" class="text-[var(--md-sys-color-primary)] hover:underline inline-block mt-4">&larr; Back</a>
  </main>
</Layout>
