# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name

# Turso Database
TURSO_DB_URL=libsql://your-db-url.turso.io
TURSO_DB_AUTH_TOKEN=your_auth_token

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/callback/discord
DISCORD_REDIRECT_URI_DEV=http://localhost:4321/api/auth/callback/discord

# JWT Session
JWT_SECRET=your_jwt_secret

# Proxy and Security
PUBLIC_VIDEO_PROXY_URL=https://your-worker-name.your-subdomain.workers.dev
ALLANIME_DECRYPTION_KEY=your_allanime_decryption_key
